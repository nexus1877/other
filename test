            local okLoad, loadResult = pcall(function()
                return loadstring(src)
            end)
            if okLoad and type(loadResult) == "function" then
                fn = loadResult
            else
                err = loadResult or "loadstring failed"
            end
            if fn then
                local okRun, runErr = pcall(fn)
                if okRun then
                    exec.Text = "[v] Executed"
                    exec.BackgroundColor3 = THEME.Success
                else
                    exec.Text = "[x] Runtime Error"
