                exec.BackgroundColor3 = THEME.Danger
                warn("[PurpleScripts] Load:", err)
            end
            task.wait(2)
            exec.Text = "> Execute"
            exec.BackgroundColor3 = THEME.Purple
        end)
    end)
end

local function httpGet(url)
    local ok, res = pcall(function()
        if syn and syn.request then
            return syn.request({Url = url, Method = "GET"}).Body
        elseif http_request then
            return http_request({Url = url, Method = "GET"}).Body
        elseif request then
            return request({Url = url, Method = "GET"}).Body
        else
            return game:HttpGet(url)
        end
    end)
    if ok then return res end
    return nil
end

local function fetchScripts(query)
    local url
    if query and query ~= "" then
        url = "https://scriptblox.com/api/script/search?q=" .. HttpService:UrlEncode(query) .. "&max=15&mode=free&page=1"
    else
        url = "https://scriptblox.com/api/script/fetch?page=1"
    end
    local body = httpGet(url)
    if not body then return nil, "No response" end
    local ok, data = pcall(function() return HttpService:JSONDecode(body) end)
    if not ok then return nil, "Parse error" end
    local scripts = data and data.result and data.result.scripts or {}
    local out = {}
    for _, s in ipairs(scripts) do
        table.insert(out, {
            title      = s.title,
            script     = s.script,
            views      = s.views,
            scriptType = s.scriptType,
            gameName   = s.game and s.game.name or "Universal",
        })
        if #out >= 15 then break end
    end
    return out
end

local currentToken = 0
local function loadScripts(query)
    currentToken = currentToken + 1
    local token = currentToken
    showMessage("Loading...", THEME.SubText)
    Status.Text = query and query ~= "" and ('Results: "' .. query .. '"') or "Top Scripts"
    task.spawn(function()
        local list, err = fetchScripts(query)
        if token ~= currentToken then return end
        clearList()
        if not list or #list == 0 then
            showMessage(err or "X No results", THEME.Danger)
            return
        end
        for i, s in ipairs(list) do
            makeCard(s, i)
        end
    end)
end

