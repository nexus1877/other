local function corner(p, r)
    local c = Instance.new("UICorner", p); c.CornerRadius = UDim.new(0, r or 10); return c
end
local function stroke(p, col, t, trans)
    local s = Instance.new("UIStroke", p)
    s.Color = col or THEME.Stroke
    s.Thickness = t or 1
    s.Transparency = trans or 0.4
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    return s
end
local function pad(p, all)
    local u = Instance.new("UIPadding", p)
    u.PaddingTop = UDim.new(0, all); u.PaddingBottom = UDim.new(0, all)
    u.PaddingLeft = UDim.new(0, all); u.PaddingRight = UDim.new(0, all)
    return u
end
local function tween(o, t, props, style, dir)
    local tw = TweenService:Create(o, TweenInfo.new(t, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out), props)
    tw:Play(); return tw
end

