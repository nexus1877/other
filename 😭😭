local function GetStabilizer(root)
    if root and not root:FindFirstChild("DanielStabilizer") then
        local vel = Instance.new("BodyAngularVelocity")
        vel.Name = "DanielStabilizer"
        vel.AngularVelocity = Vector3.new(0, 0, 0)
        vel.MaxTorque = Vector3.new(50000, 50000, 50000)
        vel.P = 1250
        vel.Parent = root
    end
end

local function RemoveStabilizer(root)
    if root and root:FindFirstChild("DanielStabilizer") then
        root.DanielStabilizer:Destroy()
    end
end

local DanielActionLoop = nil
local DanielBangAnim = nil
local lastHum = nil

local function ToggleHeadSit(state, TargetPlayer, LP, RS)
    if DanielActionLoop then DanielActionLoop:Disconnect(); DanielActionLoop = nil end

    if state then
        DanielActionLoop = RS.Heartbeat:Connect(function()
            pcall(function()
                local myChar = LP.Character
                local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
                local myHum = myChar and myChar:FindFirstChild("Humanoid")

                local tChar = TargetPlayer and TargetPlayer.Character
                local tHum = tChar and tChar:FindFirstChild("Humanoid")
                local tHead = tChar and tChar:FindFirstChild("Head")

                if not tChar or not tHum or tHum.Health <= 0 then
                    if myHum then myHum.Sit = false end
                    return
                end

                if myRoot and myHum then
                    myHum.BreakJointsOnDeath = false
                    GetStabilizer(myRoot)

                    if myHum.Health > 0 then
                        myHum.Sit = true
                    end

                    if tHead then
                        myRoot.CFrame = tHead.CFrame * CFrame.new(0, 2, 0)
                        _G.DanielLastTargetHead = tHead.CFrame
                    elseif _G.DanielLastTargetHead then
                        myRoot.CFrame = _G.DanielLastTargetHead * CFrame.new(0, 2, 0)
                    end
                    myRoot.Velocity = Vector3.new(0, 0, 0)
                end
            end)
        end)
    else
        pcall(function()
            local myChar = LP.Character
            local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
            local myHum = myChar and myChar:FindFirstChild("Humanoid")
            if myHum then
                myHum.Sit = false
                myHum.BreakJointsOnDeath = true
            end
            if myRoot then RemoveStabilizer(myRoot) end
        end)
    end
end

local function ToggleBangTarget(state, TargetPlayer, LP, RS)
    if DanielActionLoop then DanielActionLoop:Disconnect(); DanielActionLoop = nil end
    if DanielBangAnim then pcall(function() DanielBangAnim:Stop() end); DanielBangAnim = nil end
    lastHum = nil

    if state then
        DanielActionLoop = RS.Heartbeat:Connect(function()
            pcall(function()
                local myChar = LP.Character
                local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
                local myHum = myChar and myChar:FindFirstChild("Humanoid")

                local tChar = TargetPlayer and TargetPlayer.Character
                local tHum = tChar and tChar:FindFirstChild("Humanoid")
                local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")

                if not tChar or not tHum or tHum.Health <= 0 then return end

                if myRoot and myHum then
                    myHum.BreakJointsOnDeath = false
                    GetStabilizer(myRoot)

                    if myHum ~= lastHum and myHum.Health > 0 then
                        lastHum = myHum
                        if DanielBangAnim then pcall(function() DanielBangAnim:Stop() end) end

                        local animator = myHum:FindFirstChildOfClass("Animator")
                        if not animator then
                            animator = Instance.new("Animator")
                            animator.Parent = myHum
                        end

                        local Anim = Instance.new("Animation")
                        Anim.AnimationId = "rbxassetid://5918726674"
                        DanielBangAnim = animator:LoadAnimation(Anim)
                        DanielBangAnim:Play(0.1, 1, BangBackSpeed / 10)
                    end

                    if myHum.Health > 0 and DanielBangAnim then
                        if not DanielBangAnim.IsPlaying then
                            pcall(function() DanielBangAnim:Play(0.1, 1, BangBackSpeed / 10) end)
                        else
                            pcall(function() DanielBangAnim:AdjustSpeed(BangBackSpeed / 10) end)
                        end
                    end

                    local offset = math.sin(tick() * BangBackSpeed) * 0.5

                    if tRoot then
                        myRoot.CFrame = tRoot.CFrame * CFrame.new(0, 0, 1.1 + offset)
                        _G.DanielLastTargetCFrame = tRoot.CFrame
                    elseif _G.DanielLastTargetCFrame then
                        myRoot.CFrame = _G.DanielLastTargetCFrame * CFrame.new(0, 0, 1.1 + offset)
                    end
                    myRoot.Velocity = Vector3.new(0, 0, 0)
                end
            end)
        end)
    else
        pcall(function()
            local myChar = LP.Character
            local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
            local myHum = myChar and myChar:FindFirstChild("Humanoid")
            if myHum then myHum.BreakJointsOnDeath = true end
            if myRoot then RemoveStabilizer(myRoot) end
            if DanielBangAnim then pcall(function() DanielBangAnim:Stop() end); DanielBangAnim = nil end
        end)
    end
end

